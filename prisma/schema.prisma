generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Source {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  base_url    String
  auth_type   String
  last_synced DateTime? @db.Timestamptz
  is_active   Boolean   @default(true)

  @@map("sources")
}

model Opportunity {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_system       String
  source_notice_id    String?
  ocid                String    @unique
  notice_type         String?
  title               String?
  description_raw     String?
  description_summary String?
  buyer_name          String?
  buyer_identifier    String?
  buyer_type          String?
  published_at        DateTime? @db.Timestamptz
  updated_at          DateTime? @db.Timestamptz
  tender_deadline     DateTime? @db.Timestamptz
  contract_start      DateTime? @db.Date
  contract_end        DateTime? @db.Date
  value_min           Decimal?  @db.Decimal
  value_max           Decimal?  @db.Decimal
  currency            String    @default("GBP")
  framework_flag      Boolean   @default(false)
  lots_flag           Boolean   @default(false)
  lot_count           Int?
  location_text       String?
  region_code         String?
  postcode            String?
  cpv_primary         String?
  cpv_additional      String[]
  keywords            String[]
  documents           Json?
  status              String    @default("live")
  source_url          String?
  raw_payload         Json?
  created_at          DateTime  @default(now()) @db.Timestamptz

  ai_extractions AiExtraction[]
  match_scores   MatchScore[]

  @@index([cpv_primary])
  @@index([status])
  @@index([tender_deadline])
  @@index([source_system])
  @@map("opportunities")
}

model Buyer {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String  @unique
  name       String?
  type       String?
  region     String?

  @@map("buyers")
}

model SyncLog {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_system   String
  started_at      DateTime  @db.Timestamptz
  completed_at    DateTime? @db.Timestamptz
  notices_fetched Int?
  notices_new     Int?
  notices_updated Int?
  error           String?

  @@map("sync_logs")
}

model Waitlist {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String   @unique
  trade      String?
  company    String?
  created_at DateTime @default(now()) @db.Timestamptz

  @@map("waitlist")
}

model AiExtraction {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opportunity_id String   @db.Uuid
  trade_class    String?
  risk_flags     String[]
  summary        String?
  fit_signals    Json?
  model          String?
  created_at     DateTime @default(now()) @db.Timestamptz

  opportunity Opportunity @relation(fields: [opportunity_id], references: [id], onDelete: Cascade)

  @@unique([opportunity_id])
  @@map("ai_extractions")
}

model UserProfile {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @unique
  email      String
  trade      String?
  company    String?
  regions    String[]
  value_min  Decimal? @db.Decimal
  value_max  Decimal? @db.Decimal
  target_cpvs String[]
  digest_frequency String @default("daily")
  digest_enabled   Boolean @default(true)
  last_digest_at   DateTime? @db.Timestamptz
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  match_scores MatchScore[]

  @@map("user_profiles")
}

model MatchScore {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  opportunity_id String   @db.Uuid
  trade_score    Decimal? @db.Decimal
  geo_score      Decimal? @db.Decimal
  value_score    Decimal? @db.Decimal
  buyer_score    Decimal? @db.Decimal
  timing_score   Decimal? @db.Decimal
  overall_score  Decimal? @db.Decimal
  created_at     DateTime @default(now()) @db.Timestamptz

  user        UserProfile @relation(fields: [user_id], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunity_id], references: [id], onDelete: Cascade)

  @@unique([user_id, opportunity_id])
  @@index([overall_score])
  @@map("match_scores")
}

model KnowledgeDocument {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String
  file_name  String
  file_type  String   // "proposal", "cv", "case_study", "cert", "company_profile", "other"
  file_url   String
  file_size  Int
  status     String   @default("processing") // "processing", "ready", "error"
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  chunks KnowledgeChunk[]

  @@index([user_id])
  @@index([file_type])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_id String   @db.Uuid
  user_id     String
  content     String
  metadata    Json?
  created_at  DateTime @default(now()) @db.Timestamptz

  document KnowledgeDocument @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([document_id])
  @@map("knowledge_chunks")
}

model GoNoGoAnalysis {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opportunity_id String   @db.Uuid
  user_id        String
  recommendation String   // "GO", "NO-GO", "CONDITIONAL"
  confidence     String   // "HIGH", "MEDIUM", "LOW"
  analysis       Json
  created_at     DateTime @default(now()) @db.Timestamptz

  @@unique([opportunity_id, user_id])
  @@map("go_no_go_analyses")
}

model ProposalDraft {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String
  opportunity_id String   @db.Uuid
  content        String
  version        Int      @default(1)
  is_latest      Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @db.Timestamptz

  collaborators ProposalCollaborator[]

  @@index([user_id, opportunity_id])
  @@index([is_latest])
  @@map("proposal_drafts")
}

model ProposalCollaborator {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  proposal_id   String   @db.Uuid
  user_id       String
  role          String   @default("editor") // "owner", "editor", "viewer"
  invited_email String?
  accepted      Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamptz

  proposal ProposalDraft @relation(fields: [proposal_id], references: [id], onDelete: Cascade)

  @@unique([proposal_id, user_id])
  @@index([user_id])
  @@map("proposal_collaborators")
}
